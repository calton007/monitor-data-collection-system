<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
  <class name="com.file.TSystemuser" table="t_systemuser">
    <id name="id" column="Id" type="java.lang.Integer">
      <generator class="identity"/>
    </id>
    <property name="employNumber" column="EmployNumber" type="java.lang.Integer"/>
    <property name="employName" column="EmployName" type="java.lang.String"/>
    <property name="employType" column="EmployType" type="java.lang.String"/>
    <property name="sex" column="Sex" type="java.lang.String"/>
    <property name="level" column="Level" type="java.lang.String"/>
    <property name="userName" column="UserName" type="java.lang.String"/>
    <property name="password" column="Password" type="java.lang.String"/>
    <property name="department" column="Department" type="java.lang.String"/>
    <property name="group" column="`Group`" type="java.lang.String"/>
  </class>
</hibernate-mapping>
