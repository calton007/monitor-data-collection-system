<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
  <class name="com.file.TMonitordata" table="t_monitordata">
    <id name="id" column="Id" type="java.lang.Integer">
      <generator class="identity"/>
    </id>
    <property name="monitorId" column="MonitorId" type="java.lang.Integer"/>
    <property name="monitorName" column="MonitorName" type="java.lang.String"/>
    <property name="monitorItem" column="MonitorItem" type="java.lang.String"/>
    <property name="monitorDateTime" column="MonitorDateTime" type="java.sql.Timestamp"/>
    <property name="data" column="Data" type="java.lang.Float"/>
  </class>
</hibernate-mapping>
